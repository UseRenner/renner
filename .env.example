NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — used server-side by the admin notification route to
# look up the email of the other party in disputes / safety alerts.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Admin alerting (Resend). Leave both blank to silently disable.
ADMIN_EMAIL=alerts@your-domain.com
RESEND_API_KEY=your-resend-api-key
